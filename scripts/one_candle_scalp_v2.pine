//@version=6
strategy("One Candle Scalp v2 — Filtered", overlay=true, max_bars_back=500, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// ─── Inputs ───
showBox          = input.bool(true, "Show Opening Range Box", group="Display")
showLabels       = input.bool(true, "Show Entry Labels", group="Display")
tradingStart     = input.int(930, "Session Start (HHMM)", group="Session")
tradingEnd       = input.int(1100, "Session End (HHMM)", group="Session")
maxTradesPerDay  = input.int(2, "Max Trades Per Day", minval=1, maxval=5, group="Session")

// ATR filter
atrPctThreshold  = input.float(20.0, "Manipulation Candle ATR %", minval=10, maxval=40, group="ATR Filter")
useAtrFilter     = input.bool(true, "Require ATR Manipulation Filter", group="ATR Filter")

// RVOL filter
useRvolFilter    = input.bool(true, "Require RVOL Filter", group="Volume Filter")
rvolLength       = input.int(12, "Volume MA Length", minval=5, maxval=50, group="Volume Filter")
rvolThreshold    = input.float(1.2, "RVOL Threshold", minval=1.0, maxval=3.0, step=0.1, group="Volume Filter", tooltip="Breakout candle volume must be >= this × average volume")

// Range width filter
useRangeFilter   = input.bool(true, "Require Range Width Filter", group="Range Filter")
minRangePct      = input.float(0.1, "Min Range % of Price", minval=0.05, maxval=1.0, step=0.05, group="Range Filter", tooltip="Skip if opening range is too narrow")
maxRangePct      = input.float(3.0, "Max Range % of Price", minval=1.0, maxval=10.0, step=0.5, group="Range Filter", tooltip="Skip if opening range is too wide (gap risk)")

// Trend filter
useTrendFilter   = input.bool(false, "Require 1H Trend Filter", group="Trend Filter")
trendEmaLen      = input.int(50, "1H Trend EMA Length", minval=20, maxval=200, group="Trend Filter", tooltip="Only trade in direction of 1-hour EMA trend")

// ─── Session helpers ───
timeAllowed(t) =>
    hhmm = hour(t) * 100 + minute(t)
    hhmm >= tradingStart and hhmm < tradingEnd

isSessionStart(t) =>
    hhmm = hour(t) * 100 + minute(t)
    hhmm == tradingStart

isNewDay(t) =>
    ta.change(time("D")) != 0

// ─── 15-minute opening range tracking ───
var int    barInOpening    = 0
var bool   openingComplete = false
var float  openRangeHigh   = na
var float  openRangeLow    = na

if isSessionStart(time)
    barInOpening    := 0
    openingComplete := false
    openRangeHigh   := high
    openRangeLow    := low
    barInOpening    := 1
else if not openingComplete and barInOpening > 0 and barInOpening < 3
    openRangeHigh := math.max(openRangeHigh, high)
    openRangeLow  := math.min(openRangeLow, low)
    barInOpening  := barInOpening + 1
    if barInOpening == 3
        openingComplete := true

// ─── ATR manipulation filter ───
dailyATR  = request.security(syminfo.tickerid, "D", ta.atr(14))
rangeSize = openRangeHigh - openRangeLow
isManipulation = not na(dailyATR) and dailyATR > 0 and (rangeSize / dailyATR) * 100 >= atrPctThreshold
atrPass   = useAtrFilter ? (openingComplete and isManipulation) : openingComplete

// ─── Range width filter ───
rangePctOfPrice = close > 0 ? (rangeSize / close) * 100 : 0
rangeWidthOk = not useRangeFilter or (rangePctOfPrice >= minRangePct and rangePctOfPrice <= maxRangePct)

// ─── RVOL filter ───
volMA     = ta.sma(volume, rvolLength)
rvol      = volMA > 0 ? volume / volMA : 0
rvolOk    = not useRvolFilter or rvol >= rvolThreshold

// ─── 1-Hour trend filter ───
hrEma     = request.security(syminfo.tickerid, "60", ta.ema(close, trendEmaLen))
bullTrend = not useTrendFilter or close > hrEma
bearTrend = not useTrendFilter or close < hrEma

// ─── Previous Day High / Low ───
pdh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
pdl = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_on)

// ─── Pre-market High / Low ───
pmh = request.security(syminfo.tickerid, "D", high, lookahead=barmerge.lookahead_on)
pml = request.security(syminfo.tickerid, "D", low,  lookahead=barmerge.lookahead_on)

// ─── VWAP bias ───
bullBias = close > ta.vwap(hlc3)
bearBias = close < ta.vwap(hlc3)

// ─── Combined filter gate ───
filterPass = atrPass and rangeWidthOk

// ─── State tracking ───
var bool   brokeAbove      = false
var bool   brokeBelow      = false
var bool   longEntryReady  = false
var bool   shortEntryReady = false
var int    tradesToday     = 0

if isSessionStart(time)
    brokeAbove      := false
    brokeBelow      := false
    longEntryReady  := false
    shortEntryReady := false
    tradesToday     := 0

// ─── Breakout detection (requires RVOL on breakout candle) ───
if filterPass and tradesToday < maxTradesPerDay and timeAllowed(time)
    if not brokeAbove and close > openRangeHigh and rvolOk and bullTrend
        brokeAbove     := true
        longEntryReady := true
    if not brokeBelow and close < openRangeLow and rvolOk and bearTrend
        brokeBelow      := true
        shortEntryReady := true

// ─── Retest entry ───
longRetest  = brokeAbove  and longEntryReady  and low <= openRangeHigh and close > openRangeHigh and bullBias
shortRetest = brokeBelow  and shortEntryReady and high >= openRangeLow and close < openRangeLow and bearBias

// ─── Wick confirmation ───
isHammer(o, h, l, c) =>
    candleRange = h - l
    candleRange > 0 ? (math.min(o, c) - l) / candleRange >= 0.6 : false

isInvHammer(o, h, l, c) =>
    candleRange = h - l
    candleRange > 0 ? (h - math.max(o, c)) / candleRange >= 0.6 : false

bullCandle = close > open
bearCandle = close < open
wickConfirmLong  = bullCandle and (isHammer(open, high, low, close) or bullCandle)
wickConfirmShort = bearCandle and (isInvHammer(open, high, low, close) or bearCandle)

// ─── Dynamic stop using ATR ───
atr5m     = ta.atr(14)
longStop  = openRangeLow - atr5m * 0.5
shortStop = openRangeHigh + atr5m * 0.5
longTP    = openRangeHigh + (openRangeHigh - openRangeLow) * 2
shortTP   = openRangeLow - (openRangeHigh - openRangeLow) * 2

// ─── Entries ───
if longRetest and wickConfirmLong and tradesToday < maxTradesPerDay and timeAllowed(time)
    strategy.entry("Long", strategy.long)
    strategy.exit("TP", "Long", stop=longStop, limit=longTP)
    longEntryReady  := false
    tradesToday     := tradesToday + 1
    if showLabels
        label.new(bar_index, low, "L", color=color.green, textcolor=color.white, style=label.style_label_up, size=size.small)

if shortRetest and wickConfirmShort and tradesToday < maxTradesPerDay and timeAllowed(time)
    strategy.entry("Short", strategy.short)
    strategy.exit("TP", "Short", stop=shortStop, limit=shortTP)
    shortEntryReady := false
    tradesToday     := tradesToday + 1
    if showLabels
        label.new(bar_index, high, "S", color=color.red, textcolor=color.white, style=label.style_label_down, size=size.small)

// ─── Auto-close at session end ───
if not timeAllowed(time) and strategy.position_size != 0
    strategy.close_all(comment="Session End")

// ─── Draw opening range box ───
if showBox and openingComplete and isSessionStart(time[2])
    box.new(bar_index - 2, openRangeHigh, bar_index + 20, openRangeLow, bgcolor=color.new(color.purple, 85), border_color=color.purple)
    line.new(bar_index - 2, openRangeHigh, bar_index + 20, openRangeHigh, color=color.blue, style=line.style_dashed)
    line.new(bar_index - 2, openRangeLow,  bar_index + 20, openRangeLow,  color=color.orange, style=line.style_dashed)

// ─── Plots ───
plot(pdh, "PDH", color=color.new(color.teal, 40), style=plot.style_stepline, linewidth=1)
plot(pdl, "PDL", color=color.new(color.red, 40),  style=plot.style_stepline, linewidth=1)
plot(hrEma, "1H EMA", color=color.new(color.yellow, 60), style=plot.style_line, linewidth=1)
bgcolor(rvol >= rvolThreshold and useRvolFilter ? color.new(color.green, 95) : na, title="RVOL Highlight")